# Opsiyonel yerel ayarlar
# API anahtarlari panelden girilir, bu dosyada saklanmaz.
#
# Bu dosyayi .env olarak kopyalayacaksaniz bos degerleri aktif satir olarak kullanmayin.
# Satir basi # ile acik birakilirsa uygulama varsayilan ayarlari kullanir.

# PORT=3000
# APP_DATA_DIR=C:\Users\YourUser\AppData\Roaming\whatsappisletme
# DATABASE_PATH=C:\Users\YourUser\AppData\Roaming\whatsappisletme\app.sqlite
# START_WHATSAPP=true
# KNOWLEDGE_EMBEDDINGS=hash
