{
  "name": "whatsappisletme",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:react": "tsx watch src/server.ts",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "build:react": "tsc -p tsconfig.json && vite build",
    "build": "npm run build:react && electron-builder --win",
    "build:publish": "npm run build:react && electron-builder --win --publish always",
    "start": "node dist/src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.59.0",
    "@google/genai": "^1.12.0",
    "@huggingface/transformers": "^3.7.1",
    "@wppconnect-team/wppconnect": "^1.37.4",
    "better-sqlite3": "^12.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "mammoth": "^1.10.0",
    "openai": "^5.11.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^3.25.76",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.1.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^10.0.3",
    "electron": "^31.2.0",
    "electron-builder": "^26.15.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.6",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.otoasistan.app",
    "productName": "OtoAsistan",
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "src/persistence/**/*"
    ],
    "extraResources": [
      "build/icon.png"
    ],
    "mac": {
      "icon": "build/icon.png"
    },
    "win": {
      "icon": "build/icon.png",
      "target": "nsis",
      "verifyUpdateCodeSignature": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Rwin20",
        "repo": "OtoAsistan"
      }
    ]
  }
}
